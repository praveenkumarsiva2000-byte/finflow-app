{
  "info": {
    "name": "FinFlow API",
    "description": "Complete API collection for FinFlow Personal Finance Manager",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:5000/api", "type": "string" },
    { "key": "token", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/signup",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Praveen Kumar\",\n  \"email\": \"praveen@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [{
            "listen": "test",
            "script": { "exec": ["const r = pm.response.json(); if(r.token) { pm.collectionVariables.set('token', r.token); }"] }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"praveen@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/reset-password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"praveen@example.com\",\n  \"newPassword\": \"newpassword123\"\n}"
            }
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/auth/profile"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/auth/profile",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Praveen Kumar Siva\",\n  \"preferences\": {\n    \"currency\": \"INR\",\n    \"notifications\": {\n      \"budgetAlerts\": true,\n      \"goalReminders\": true,\n      \"weeklyReport\": false\n    }\n  }\n}"
            }
          }
        },
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/health"
          }
        }
      ]
    },
    {
      "name": "Expenses",
      "item": [
        {
          "name": "Get All Expenses",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/expenses"
          }
        },
        {
          "name": "Get Expenses with Filters",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/expenses?category=food&dateFrom=2026-06-01&dateTo=2026-06-30",
              "query": [
                { "key": "category", "value": "food" },
                { "key": "dateFrom", "value": "2026-06-01" },
                { "key": "dateTo", "value": "2026-06-30" }
              ]
            }
          }
        },
        {
          "name": "Add Expense",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/expenses",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 250,\n  \"category\": \"food\",\n  \"date\": \"2026-06-07\",\n  \"note\": \"Lunch at cafe\",\n  \"isRecurring\": false\n}"
            }
          }
        },
        {
          "name": "Delete Expense",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/expenses/EXPENSE_ID_HERE"
          }
        },
        {
          "name": "Clear All Expenses",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/expenses/all"
          }
        }
      ]
    },
    {
      "name": "Incomes",
      "item": [
        {
          "name": "Get All Incomes",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/incomes"
          }
        },
        {
          "name": "Add Income",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/incomes",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 50000,\n  \"source\": \"Monthly Salary\",\n  \"category\": \"salary\",\n  \"date\": \"2026-06-01\",\n  \"note\": \"June salary\",\n  \"isRecurring\": true\n}"
            }
          }
        },
        {
          "name": "Delete Income",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/incomes/INCOME_ID_HERE"
          }
        }
      ]
    },
    {
      "name": "Budgets",
      "item": [
        {
          "name": "Get All Budgets",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/budgets"
          }
        },
        {
          "name": "Set Budget",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/budgets",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"category\": \"food\",\n  \"limit\": 5000,\n  \"period\": \"monthly\"\n}"
            }
          }
        },
        {
          "name": "Delete Budget",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/budgets/BUDGET_ID_HERE"
          }
        }
      ]
    },
    {
      "name": "Goals",
      "item": [
        {
          "name": "Get All Goals",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/goals"
          }
        },
        {
          "name": "Create Goal",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/goals",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Laptop\",\n  \"target\": 80000,\n  \"saved\": 15000,\n  \"deadline\": \"2026-12-31\",\n  \"emoji\": \"💻\"\n}"
            }
          }
        },
        {
          "name": "Update Goal Progress",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/goals/GOAL_ID_HERE",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"saved\": 25000\n}"
            }
          }
        },
        {
          "name": "Delete Goal",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/goals/GOAL_ID_HERE"
          }
        }
      ]
    }
  ]
}
